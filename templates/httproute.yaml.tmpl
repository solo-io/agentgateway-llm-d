apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: __HTTPROUTE_NAME__
spec:
  parentRefs:
    - group: gateway.networking.k8s.io
      kind: Gateway
      name: __INFERENCE_GATEWAY_NAME__
  rules:
    - backendRefs:
        - group: inference.networking.k8s.io
          kind: InferencePool
          name: __INFERENCEPOOL_NAME__
          port: 8000
          weight: 1
      timeouts:
        backendRequest: 0s
        request: 0s
      matches:
        - path:
            type: PathPrefix
            value: /
